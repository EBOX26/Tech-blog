<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tech Blog</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
    integrity="sha384-LzUrhlj+eDHoigDZkd9iO/dgsnUiwbcgP6VEq8G8KglqSzAVned+WTDsCWl7opkO" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <header>
    <h1><a class="title" href="/" title="Tech Insight">Tech Blog</a></h1>
  </header>

  <nav>
    <a class="link" href="/" title="Home">Home</a>
    <a class="link" href="/dashboard" title="Dashboard">Dashboard</a>
    {{#if logged_in}}
    <a class="link" href="/" id="logout" title="Logout">Logout</a>
    {{else}}
    <a class="link" href="/login" title="Login">Login</a>
    {{/if}}
  </nav>

  <main>
    {{{ body }}}
  </main>

  {{#if logged_in}}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/logout.js"></script>
  {{/if}}
</body>

</html>

