<section class="edit-delete-post-section">
    <h2>Edit or Delete Post</h2>
    <form class="edit-post-form">
        <div class="form-group">
            <label for="post-title" class="form-label">Title</label>
            <input type="text" id="title" name="post-title" value="{{post.title}}" class="form-input" />
        </div>

        <div class="form-group">
            <label for="content" class="form-label">Content</label>
            <textarea id="content" name="content" class="form-input">{{post.content}}</textarea>
        </div>
        <button id="update" type="submit" class="btn btn-primary">UPDATE POST</button>
        <button id="delete" type="submit" class="btn delete-post-btn btn-primary">DELETE POST</button>
    </form>
</section>

<script src="/js/edit-post.js"></script>
<script src="/js/delete-post.js"></script>

